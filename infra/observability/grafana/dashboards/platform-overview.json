{
  "__inputs": [{"name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus"}],
  "title": "AnalytiX – Platform Overview",
  "uid": "genquantaa-overview",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "tags": ["genquantaa", "overview"],
  "panels": [
    {
      "id": 1, "type": "stat", "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "title": "Services UP",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "count(up == 1)", "legendFormat": "Healthy"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none"},
      "fieldConfig": {"defaults": {"thresholds": {"steps": [{"color": "red", "value": 0}, {"color": "yellow", "value": 8}, {"color": "green", "value": 10}]}}}
    },
    {
      "id": 2, "type": "stat", "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "title": "Services DOWN",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "count(up == 0) OR vector(0)", "legendFormat": "Down"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {"defaults": {"thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "red", "value": 1}]}}}
    },
    {
      "id": 3, "type": "timeseries", "gridPos": {"h": 8, "w": 16, "x": 8, "y": 0},
      "title": "HTTP Request Rate (req/s) – All Services",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "sum by(job)(rate(http_requests_total[5m]))", "legendFormat": "{{job}}"}]
    },
    {
      "id": 4, "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "title": "API Latency p95 (seconds)",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "histogram_quantile(0.95, sum by(job, le)(rate(http_request_duration_seconds_bucket[5m])))", "legendFormat": "{{job}} p95"}]
    },
    {
      "id": 5, "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "title": "Error Rate (5xx) – All Services",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "rate(http_requests_total{status=~'5..'}[5m])", "legendFormat": "{{job}} errors"}]
    },
    {
      "id": 6, "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "title": "AI Copilot Response Latency p95",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "histogram_quantile(0.95, sum by(le)(rate(http_request_duration_seconds_bucket{job='ai-service'}[5m])))", "legendFormat": "AI p95"}]
    },
    {
      "id": 7, "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "title": "Workflow Executions",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "rate(workflow_executions_total{status='completed'}[5m])", "legendFormat": "completed"},
        {"expr": "rate(workflow_executions_total{status='failed'}[5m])", "legendFormat": "failed"}
      ]
    },
    {
      "id": 8, "type": "gauge", "gridPos": {"h": 4, "w": 8, "x": 0, "y": 24},
      "title": "CPU Usage",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "100 - (avg(rate(node_cpu_seconds_total{mode='idle'}[5m])) * 100)"}],
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100, "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}}}
    },
    {
      "id": 9, "type": "gauge", "gridPos": {"h": 4, "w": 8, "x": 8, "y": 24},
      "title": "Memory Usage",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100"}],
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100, "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 75}, {"color": "red", "value": 90}]}}}
    },
    {
      "id": 10, "type": "gauge", "gridPos": {"h": 4, "w": 8, "x": 16, "y": 24},
      "title": "Disk Usage",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [{"expr": "(1 - node_filesystem_avail_bytes{mountpoint='/'} / node_filesystem_size_bytes{mountpoint='/'}) * 100"}],
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100, "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 80}, {"color": "red", "value": 90}]}}}
    }
  ]
}
