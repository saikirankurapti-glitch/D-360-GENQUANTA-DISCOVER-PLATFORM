# .env.example – Supabase connection for AnalytiX Discover

# ---------------------------------------------------------------
# Copy this file to .env and replace the placeholder values.
# Do NOT commit the real .env file to version control.
# ---------------------------------------------------------------

# Supabase project
SUPABASE_PROJECT_REF=zsbcktaeasdegnihupyb
SUPABASE_URL=https://zsbcktaeasdegnihupyb.supabase.co

# Keys (Dashboard → Settings → API)
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ---------------------------------------------------------------
# Database connection string
# Get from: Dashboard → Settings → Database → Connection string → URI
# Replace [YOUR-PASSWORD] with your database password.
# ---------------------------------------------------------------
DATABASE_URL=postgresql://postgres.[zsbcktaeasdegnihupyb]:[YOUR-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# Async variant (for asyncpg – replace postgresql:// with postgresql+asyncpg://)
DATABASE_URL_ASYNC=postgresql+asyncpg://postgres.[zsbcktaeasdegnihupyb]:[YOUR-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ---------------------------------------------------------------
# FastAPI settings
# ---------------------------------------------------------------
ENVIRONMENT=development
PORT=8000

# JWT secret for auth service (generate a strong random string)
AUTH_SECRET_KEY=CHANGE_ME_TO_RANDOM_64_CHAR_STRING

# OpenAI API key for AI service (optional)
OPENAI_API_KEY=
